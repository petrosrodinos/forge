{
  "name": "3d-figures",
  "version": "1.0.0",
  "description": "Tripo 3D Generation API client",
  "main": "dist/index.js",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "agent": "ts-node src/cli.ts",
    "server": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "tripo:image-to-animated-glb": "ts-node src/scripts/tripoImageToAnimatedGlb.ts",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@google-cloud/storage": "^7.19.0",
    "@google/model-viewer": "^4.2.0",
    "@prisma/client": "6.19.3",
    "ai": "^6.0.142",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "form-data": "^4.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "prisma": "6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
